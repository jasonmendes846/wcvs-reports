{% extends "base.html.j2" %}
{% block title %}WCVS Report — {{ report.date }}{% endblock %}
{% block content %}
<section class="report-viewer">
  <nav class="report-nav">
    {% if prev %}
    <a class="report-nav-prev" href="{{ base_path }}/reports/{{ prev.date }}/index.html">← {{ prev.date }}</a>
    {% else %}
    <span class="report-nav-prev disabled">← Previous</span>
    {% endif %}
    <a class="report-nav-archive" href="{{ base_path }}/archive/index.html">Archive</a>
    {% if next_report %}
    <a class="report-nav-next" href="{{ base_path }}/reports/{{ next_report.date }}/index.html">{{ next_report.date }} →</a>
    {% else %}
    <span class="report-nav-next disabled">Next →</span>
    {% endif %}
  </nav>

  <div class="report-actions">
    <a class="btn" href="{{ base_path }}/reports/{{ report.date }}/wcvs-report-{{ report.date }}-full.pdf" target="_blank">Download PDF</a>
  </div>

  <article class="report-content">
    {{ report_html | safe }}
  </article>

  <nav class="report-nav bottom">
    {% if prev %}
    <a class="report-nav-prev" href="{{ base_path }}/reports/{{ prev.date }}/index.html">← {{ prev.date }}</a>
    {% else %}
    <span class="report-nav-prev disabled">← Previous</span>
    {% endif %}
    <a class="report-nav-archive" href="{{ base_path }}/archive/index.html">Archive</a>
    {% if next_report %}
    <a class="report-nav-next" href="{{ base_path }}/reports/{{ next_report.date }}/index.html">{{ next_report.date }} →</a>
    {% else %}
    <span class="report-nav-next disabled">Next →</span>
    {% endif %}
  </nav>
</section>
{% endblock %}
